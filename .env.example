# LLM
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen3:8b
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=sciwriter_knowledge

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# RAG
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_SEMANTIC_TOP_K=20
RAG_BM25_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# Preset
ARTICLE_PRESET=habr

# Web Search
WEB_SEARCH_MAX_RESULTS=10

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
